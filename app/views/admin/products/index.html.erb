<div class="flex h-screen w-full overflow-hidden bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display antialiased">
  <!-- Sidebar -->
  <aside class="w-64 flex-shrink-0 border-r border-slate-200 bg-white dark:bg-slate-900 dark:border-slate-800 flex flex-col justify-between">
    <div class="flex flex-col gap-6 p-4">
      <div class="px-2">
        <h1 class="text-primary text-xl font-bold tracking-tight">PRAMA</h1>
        <p class="text-slate-500 text-xs font-medium uppercase tracking-wider mt-1">Admin</p>
      </div>
      <nav class="flex flex-col gap-1">
        <%= link_to admin_products_path,
                    class: "flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary/10 text-primary dark:bg-primary/20 dark:text-gray-400" do %>
          <span class="material-symbols-outlined fill-current">inventory_2</span>
          <span class="text-sm font-medium">Sản phẩm</span>
        <% end %>
      </nav>
      <nav class="flex flex-col gap-1">
        <%= link_to admin_categories_path,
                    class: "flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary/10 text-primary dark:bg-primary/20 dark:text-gray-400" do %>
          <span class="material-symbols-outlined fill-current">category</span>
          <span class="text-sm font-medium">Danh mục</span>
        <% end %>
      </nav>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 overflow-y-auto bg-background-light dark:bg-background-dark p-8">
    <div class="mx-auto max-w-6xl flex flex-col gap-8">
      <!-- Header Section -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Danh sách sản phẩm</h2>
          <p class="text-slate-500 dark:text-slate-400 mt-1">Quản lý kho khóa cửa thông minh PRAMA cao cấp</p>
        </div>
        <%= link_to new_admin_product_path,
                    class:
                      "bg-primary hover:bg-primary text-white px-5 py-2.5 rounded-lg text-sm font-medium flex items-center gap-2 shadow-sm shadow-gray-200 dark:shadow-none transition-all" do %>
          <span class="material-symbols-outlined text-[20px]">add</span>
          Thêm sản phẩm
        <% end %>
      </div>

      <!-- Filter & Search Bar -->
      <div
        class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col md:flex-row gap-4 justify-between items-center"
      >
        <%= form_with url: admin_products_path, method: :get, local: true, class: "w-full flex flex-col md:flex-row gap-4 justify-between items-center" do %>
          <div class="relative w-full md:max-w-md">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
              <span class="material-symbols-outlined text-[20px]">search</span>
            </span>
            <%= text_field_tag :q,
                                @q,
                                placeholder: "Tìm kiếm theo tên, SKU...",
                                class:
                                  "w-full py-2.5 pl-10 pr-4 text-sm bg-slate-100 dark:bg-slate-800 border-transparent focus:border-primary focus:ring-0 focus:bg-white dark:focus:bg-slate-800 rounded-lg text-slate-900 dark:text-slate-100 placeholder-slate-400 transition-colors" %>
          </div>

          <div class="flex gap-3 w-full md:w-auto overflow-x-auto pb-1 md:pb-0">
            <div>
              <select
                name="category_id"
                class="py-2.5 pl-3 pr-8 text-sm bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-600 dark:text-slate-300 focus:border-primary focus:ring-1 focus:ring-primary cursor-pointer min-w-[160px]"
              >
                <option value="">Tất cả danh mục</option>
                <% @categories.each do |category| %>
                  <option value="<%= category.id %>" <%= "selected" if category.id.to_s == @selected_category_id.to_s %>>
                    <%= category.name %>
                  </option>
                <% end %>
              </select>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Table Section -->
      <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
                <th class="py-4 px-6 text-xs font-semibold uppercase text-slate-500 dark:text-slate-400 tracking-wider w-24">Hình ảnh</th>
                <th class="py-4 px-6 text-xs font-semibold uppercase text-slate-500 dark:text-slate-400 tracking-wider">Mã SKU</th>
                <th class="py-4 px-6 text-xs font-semibold uppercase text-slate-500 dark:text-slate-400 tracking-wider">Tên sản phẩm</th>
                <th class="py-4 px-6 text-xs font-semibold uppercase text-slate-500 dark:text-slate-400 tracking-wider">Danh mục</th>
                <th class="py-4 px-6 text-xs font-semibold uppercase text-slate-500 dark:text-slate-400 tracking-wider">Thương hiệu</th>
                <th class="py-4 px-6 text-xs font-semibold uppercase text-slate-500 dark:text-slate-400 tracking-wider text-right">Giá (VNĐ)</th>
                <th class="py-4 px-6 text-xs font-semibold uppercase text-slate-500 dark:text-slate-400 tracking-wider text-right">Hành động</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
              <% if @products.any? %>
                <% @products.each do |product| %>
                  <% representative_variant = product.variants.min_by(&:id) %>
                  <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors group">
                    <td class="py-4 px-6">
                      <div
                        class="h-12 w-12 rounded-lg bg-gradient-to-tr from-slate-100 to-slate-200 dark:from-slate-700 dark:to-slate-800 overflow-hidden flex items-center justify-center"
                      >
                        <% if representative_variant&.images&.attached? %>
                          <%= image_tag representative_variant.images.first.variant(:thumb),
                                        class: "h-12 w-12 object-cover" %>
                        <% else %>
                          <span class="material-symbols-outlined text-slate-400">door_front</span>
                        <% end %>
                      </div>
                    </td>
                    <td class="py-4 px-6 text-sm font-medium text-slate-600 dark:text-slate-300">
                      <%= representative_variant&.sku.presence || "-" %>
                    </td>
                    <td class="py-4 px-6">
                      <div class="flex flex-col">
                        <span class="text-sm font-semibold text-slate-900 dark:text-white"><%= product.name %></span>
                        <% if product.description.present? %>
                          <span class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                            <%= truncate(strip_tags(product.description.to_s), length: 60) %>
                          </span>
                        <% end %>
                      </div>
                    </td>
                    <td class="py-4 px-6">
                      <% if product.category.present? %>
                        <span
                          class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-gray-50 text-primary dark:bg-gray-900/30 dark:text-gray-300 border border-gray-100 dark:border-gray-800"
                        >
                          <%= product.category.name %>
                        </span>
                      <% else %>
                        <span class="text-xs text-slate-400">Không có danh mục</span>
                      <% end %>
                    </td>
                    <td class="py-4 px-6 text-sm text-slate-600 dark:text-slate-300">
                      <%= product.brand.presence || "-" %>
                    </td>
                    <td class="py-4 px-6 text-sm font-medium text-slate-900 dark:text-white text-right">
                      <% representative_price = representative_variant&.price %>
                      <% representative_price = representative_variant&.sale if (representative_variant&.sale.present? && representative_variant&.sale > 0) %>
                    
                      <% if representative_price.present? %>
                        <% formatted_price = number_to_currency(representative_price, unit: "", precision: 0, delimiter: ".") %>
                        <%= formatted_price %> <span class="text-xs text-slate-500 dark:text-slate-400">VNĐ</span>
                      <% else %>
                        -
                      <% end %>
                    </td>
                    <td class="py-4 px-6 text-right">
                      <div class="flex items-center justify-end gap-2 opacity-60 group-hover:opacity-100 transition-opacity">
                        <%= link_to edit_admin_product_path(product),
                                    class:
                                      "p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-500 hover:text-primary dark:text-slate-400 dark:hover:text-gray-400 transition-colors",
                                    title: "Sửa" do %>
                          <span class="material-symbols-outlined text-[20px]">edit</span>
                        <% end %>
                        <%= button_to admin_product_path(product),
                                      method: :delete,
                                      data: { turbo_confirm: "Bạn có chắc muốn xóa sản phẩm này không?" },
                                      class:
                                        "p-2 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 text-slate-500 hover:text-red-600 dark:text-slate-400 dark:hover:text-red-400 transition-colors",
                                      title: "Xóa" do %>
                          <span class="material-symbols-outlined text-[20px]">delete</span>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="7" class="py-6 px-6 text-center text-sm text-slate-500 dark:text-slate-400">
                    Chưa có sản phẩm nào phù hợp với bộ lọc hiện tại.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div
          class="px-6 py-4 flex items-center justify-between border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900"
        >
          <% if defined?(@pagy) && @pagy && @pagy.count.positive? %>
            <p class="text-sm text-slate-500 dark:text-slate-400 hidden sm:block">
              Hiển thị
              <span class="font-medium text-slate-900 dark:text-white"><%= @pagy.from %></span>
              đến
              <span class="font-medium text-slate-900 dark:text-white"><%= @pagy.to %></span>
              trong tổng số
              <span class="font-medium text-slate-900 dark:text-white"><%= @pagy.count %></span>
              sản phẩm
            </p>
          <% else %>
            <p class="text-sm text-slate-500 dark:text-slate-400 hidden sm:block">
              Không có sản phẩm nào.
            </p>
          <% end %>

          <% if defined?(@pagy) && @pagy && @pagy.pages > 1 %>
            <div class="flex items-center gap-1.5 w-full sm:w-auto justify-center sm:justify-end">
              <% prev_page = @pagy.prev %>
              <% next_page = @pagy.next %>

              <%= link_to (prev_page ? pagy_url_for(@pagy, prev_page) : "#"),
                          class:
                            "p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 transition-colors #{'opacity-50 cursor-not-allowed pointer-events-none' unless prev_page}" do %>
                <span class="material-symbols-outlined text-[18px]">chevron_left</span>
              <% end %>

              <% total_pages = @pagy.pages %>
              <% current_page = @pagy.page %>
              <% pages =
                   if total_pages <= 5
                     (1..total_pages).to_a
                   else
                     [1, current_page - 1, current_page, current_page + 1, total_pages].uniq.select { |p| p >= 1 && p <= total_pages }.sort
                   end %>

              <% last_rendered = nil %>
              <% pages.each do |page_number| %>
                <% if last_rendered && page_number > last_rendered + 1 %>
                  <span class="min-w-[36px] h-9 flex items-center justify-center text-slate-400 text-sm">...</span>
                <% end %>

                <% if page_number == current_page %>
                  <span
                    class="min-w-[36px] h-9 rounded-lg bg-primary text-white text-sm font-medium flex items-center justify-center"
                  >
                    <%= page_number %>
                  </span>
                <% else %>
                  <%= link_to page_number,
                              pagy_url_for(@pagy, page_number),
                              class:
                                "min-w-[36px] h-9 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-300 text-sm font-medium flex items-center justify-center transition-colors" %>
                <% end %>

                <% last_rendered = page_number %>
              <% end %>

              <%= link_to (next_page ? pagy_url_for(@pagy, next_page) : "#"),
                          class:
                            "p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors #{'opacity-50 cursor-not-allowed pointer-events-none' unless next_page}" do %>
                <span class="material-symbols-outlined text-[18px]">chevron_right</span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </main>
</div>
