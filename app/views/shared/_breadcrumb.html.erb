<% if @breadcrumb.present? %>
  <nav class="hidden lg:flex items-center space-x-2 text-sm text-gray-600 dark:text-gray-400 mb-4 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto my-2">
    <%= link_to "Trang chủ", root_path, class: "hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
    
    <span class="text-gray-400">/</span>
    
    <%= link_to "Sản phẩm", products_path, class: "hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
    
    <% @breadcrumb.each_with_index do |category, index| %>
      <span class="text-gray-400">/</span>
      
      <% if index == @breadcrumb.length - 1 && !@product %>
        <!-- Current category - không có link (trang danh sách sản phẩm) -->
        <span class="text-gray-900 dark:text-white font-medium"><%= category.name %></span>
      <% else %>
        <!-- Parent categories hoặc category trong trang chi tiết - có link -->
        <%= link_to category.name, products_path(category: category.id), 
            class: "hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
      <% end %>
    <% end %>
    
    <% if @product %>
      <span class="text-gray-400">/</span>
      <span class="text-gray-900 dark:text-white font-medium"><%= @product.name %></span>
    <% end %>
  </nav>
<% end %>