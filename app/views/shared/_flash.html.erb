<% if flash.present? %>
  <div class="fixed top-4 right-4 z-50 flex justify-end px-4 sm:px-6">
    <div class="w-full max-w-sm space-y-2">
      <% flash.each do |type, message| %>
        <% next if message.blank? %>
        <% color_classes =
             case type.to_s
             when "notice"
               "bg-emerald-50 text-emerald-800 border-emerald-200 dark:bg-emerald-900/30 dark:text-emerald-200 dark:border-emerald-800"
             when "alert", "error"
               "bg-red-50 text-red-800 border-red-200 dark:bg-red-900/30 dark:text-red-200 dark:border-red-800"
             else
               "bg-slate-50 text-slate-800 border-slate-200 dark:bg-slate-900/60 dark:text-slate-100 dark:border-slate-700"
             end %>
        <div
          class="flex items-start gap-3 rounded-lg border px-4 py-3 shadow-sm backdrop-blur-sm transition-all duration-150 <%= color_classes %>"
          data-controller="dismissable"
        >
          <div class="mt-0.5">
            <span class="material-symbols-outlined text-[20px]">
              <% if type.to_s == "notice" %>
                check_circle
              <% elsif type.to_s == "alert" || type.to_s == "error" %>
                error
              <% else %>
                info
              <% end %>
            </span>
          </div>
          <div class="flex-1 text-sm">
            <%= message %>
          </div>
          <button
            type="button"
            class="ml-2 inline-flex h-7 w-7 items-center justify-center rounded-full hover:bg-black/5 dark:hover:bg-white/10"
            data-action="click->dismissable#hide"
          >
            <span class="material-symbols-outlined text-[18px]">close</span>
          </button>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

