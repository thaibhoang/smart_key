<%= render 'shared/header' %>

<%# Khai báo dữ liệu hình ảnh %>
<% images = @selected_variant&.sorted_images || [] %>
<% image_urls = images.map { |img| url_for(img.variant(:standard)) } %>
<% thumb_urls = images.map { |img| url_for(img.variant(:thumb)) } %>

<%# Tăng max-w lên để hiển thị đẹp trên PC rộng %>
<main class="max-w-7xl mx-auto pt-10" data-controller="product-gallery">
  
  <%# WRAPPER CHO PHẦN TRÊN: CHIA 2 CỘT TRÊN PC %>
  <div class="lg:grid lg:grid-cols-2 lg:gap-12 lg:items-start px-4">
    
    <%# CỘT TRÁI: GALLERY %>
    <div class="product-gallery-wrapper">
      <%# SECTION 1: ẢNH CHÍNH %>
      <section class="relative bg-gray-100 dark:bg-gray-800 rounded-2xl overflow-hidden group/gallery">
        <div class="aspect-[4/5] sm:aspect-square w-full relative touch-pan-y"
            data-action="touchstart->product-gallery#touchStart touchend->product-gallery#touchEnd 
            touchmove->product-gallery#touchMove">
          
          <img data-product-gallery-target="mainImage"
              alt="<%= @product.name %>"
              class="w-full h-full object-cover transition-opacity duration-300 pointer-events-none select-none"
              src="<%= image_urls.first || image_path('placeholder.png') %>" />
      
          <% if image_urls.size > 1 %>
            <%# Nút Previous %>
            <button data-action="click->product-gallery#previous" 
                    class="absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/5 backdrop-blur-md text-black flex items-center justify-center opacity-0 group-hover/gallery:opacity-100 transition-all duration-300 hover:bg-black/20 active:scale-90 z-20">
              <span class="material-symbols-outlined !text-2xl">chevron_left</span>
            </button>
      
            <%# Nút Next %>
            <button data-action="click->product-gallery#next" 
                    class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/5 backdrop-blur-md text-black flex items-center justify-center opacity-0 group-hover/gallery:opacity-100 transition-all duration-300 hover:bg-black/20 active:scale-90 z-20">
              <span class="material-symbols-outlined !text-2xl">chevron_right</span>
            </button>
      
            <%# Dots chỉ số ảnh %>
            <div class="hidden md:flex absolute bottom-4 left-0 right-0 justify-center items-center space-x-2 z-10">
              <% 5.times do %>
                <button data-product-gallery-target="dot" 
                        data-action="click->product-gallery#goToDot" 
                        class="h-2 w-2 bg-gray-300/50 rounded-full shadow-sm transition-all duration-300 hidden">
                </button>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>

      <%# SECTION 2: THUMBNAILS %>
      <% if image_urls.present? %>
        <section class="py-4 overflow-x-auto no-scrollbar scroll-smooth">
          <div class="px-2 flex space-x-3 min-w-max">
            <% image_urls.each_with_index do |img_url, index| %>
              <button data-product-gallery-target="thumbnail"
                      data-action="click->product-gallery#selectImage"
                      data-url="<%= img_url %>"
                      class="w-16 h-16 lg:w-20 lg:h-20 rounded-lg overflow-hidden border transition-all duration-200 hover:border-gray-500">
                <img alt="thumb" class="w-full h-full object-cover pointer-events-none" src="<%= thumb_urls[index] %>"/>
              </button>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>

    <%# CỘT PHẢI: THÔNG TIN SƠ LƯỢC %>
    <section class="py-2 lg:py-0">
      <span class="text-secondary dark:text-gray-400 text-xs font-bold tracking-wider uppercase">
        <%= @product.brand.presence || @product.category&.name %>
      </span>
      <h2 class="text-3xl lg:text-4xl font-bold mt-1 text-gray-900 dark:text-white"><%= @product.name %></h2>

      <%
        price = @selected_variant&.price || 0
        sale_price = @selected_variant&.sale
        has_sale = sale_price.to_f > 0 && sale_price < price
      %>
      <div class="flex items-center justify-between mt-4">
        <div class="flex items-baseline space-x-3">
          <% if has_sale %>
            <span class="text-3xl font-bold text-gray-900 dark:text-white">
              <%= number_to_currency(sale_price, unit: "₫", precision: 0, format: "%n %u") %>
            </span>
            <span class="text-lg text-gray-400 line-through decoration-1">
              <%= number_to_currency(price, unit: "₫", precision: 0, format: "%n %u") %>
            </span>
          <% else %>
            <span class="text-3xl font-bold text-gray-900 dark:text-white">
              <%= number_to_currency(price, unit: "₫", precision: 0, format: "%n %u") %>
            </span>
          <% end %>
        </div>
      </div>

      <%# VARIANT SELECTION %>
      <% if @product.variants.any? %>
        <div class="mt-8 p-4 bg-gray-50 dark:bg-gray-800/50 rounded-xl">
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">
            Phiên bản: <span class="text-secondary font-bold" data-product-gallery-target="variantName"><%= @selected_variant&.color %></span>
          </p>
          <div class="flex flex-wrap gap-3">
            <% @product.variants.each do |variant| %>
              <% is_active = (variant == @selected_variant) %>
              <%= link_to product_path(@product, variant_id: variant.id),
                  class: "px-5 py-2.5 rounded-full text-sm font-medium transition-all #{is_active ? 'bg-secondary text-white shadow-md hover:bg-secondary/80' : 'bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-200 hover:border-gray-400 hover:bg-gray-300'}" do %>
                <%= variant.color %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# RICH TEXT: MAIN FEATURES %>
      <% if @product.main_features.present? %>
        <div class="mt-12">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Tính năng nổi bật</h3>
          <div class="prose prose-base dark:prose-invert max-w-none">
            <%= @product.main_features %>
          </div>
        </div>
      <% end %>

      <%# Nút mua hàng (Gợi ý thêm để tối ưu layout PC) %>
      <div class="mt-8">
      <a href="https://zalo.me/0961624398" target="_blank"
        class="block text-center w-full cursor-pointer bg-secondary hover:bg-primary text-white font-bold py-4 rounded-xl shadow-lg transition-all duration-300 ease-in-out transform active:scale-[0.98]">
        LIÊN HỆ NGƯỜI BÁN
      </a>
      </div>
    </section>
  </div>

  <%# CÁC PHẦN DƯỚI ĐÂY VẪN CHIẾM FULL WIDTH %>
  <div class="max-w-4xl mx-auto lg:mx-0 lg:max-w-none px-4">
    

    <%# SECTION 4: DETAILS & SPECS %>
    <% if @product.details.present? %>
      <hr class="my-12 border-gray-200 dark:border-gray-700"/>
      <section>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Mô tả chi tiết</h3>
        <div class="prose prose-base dark:prose-invert max-w-none trix-content">
          <%= @product.details %>
        </div>
      </section>
    <% end %>

    <% if @specifications.any? %>
      <section class="mb-12 mt-12">
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Thông số kỹ thuật</h3>
        <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden text-sm lg:text-base">
          <% @specifications.each_with_index do |spec, index| %>
            <div class="grid grid-cols-3 border-b border-gray-200 dark:border-gray-700 p-5 <%= 'bg-gray-50 dark:bg-gray-800/50' if index.odd? %> last:border-0">
              <div class="text-gray-500 dark:text-gray-400 font-medium"><%= spec.name %></div>
              <div class="col-span-2 font-medium text-gray-900 dark:text-white text-right sm:text-left"><%= spec.content %></div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <%# SECTION 5: RELATED PRODUCTS - ĐÃ CHỈNH LÊN 4 CỘT TRÊN PC %>
    <% if @related_products.any? %>
      <section class="mb-12">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white">Sản phẩm liên quan</h3>
          <%= link_to "Xem tất cả", products_path, class: "text-sm font-medium text-secondary dark:text-gray-400 hover:underline" %>
        </div>
        <%# Grid thay đổi từ 2 lên 4 cột khi đạt breakpoint lg %>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          <% @related_products.each do |product| %>
            <% 
              # Logic lấy variant đầu tiên và ảnh chính
              first_variant = product.cheapest_variant
              main_image = first_variant&.images&.first
              price = first_variant&.price || 0
              sale_price = first_variant&.sale
              has_sale = sale_price.to_f > 0 && sale_price < price
              percent = (100 * (1 - sale_price.to_f / price)).to_i
            %>
            
            <div class="group bg-white dark:bg-surface-dark rounded-2xl p-4 shadow-sm hover:shadow-md transition-shadow duration-300 border border-gray-100 dark:border-gray-800 flex flex-col">
              <div class="relative rounded-xl mb-4 flex items-center justify-center h-64 overflow-hidden">
                <% if main_image.present? %>
                  <%= image_tag main_image, alt: product.name, class: "h-full w-auto object-contain transform group-hover:scale-105 transition-transform duration-300" %>
                <% else %>
                  <div class="text-gray-300 italic text-sm text-center">Chưa có ảnh</div>
                <% end %>

                <% if has_sale %>
                  <div class="absolute top-2 left-2 rounded-full bg-secondary px-2 py-1 text-[10px] font-bold text-white uppercase">
                    - <%= percent %>%
                  </div>
                <% end %>
              </div>

              <div class="flex-grow">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1 line-clamp-1"><%= product.name %></h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-3 line-clamp-2">
                  <%= product.description %>
                </p>            
                <div class="flex items-center space-x-2 mb-4">
                  <% if has_sale %>
                    <span class="text-lg font-bold text-secondary">
                      <%= number_to_currency(sale_price, unit: "₫", precision: 0, format: "%n %u") %>
                    </span>
                    <span class="text-sm text-gray-400 line-through">
                      <%= number_to_currency(price, unit: "₫", precision: 0, format: "%n %u") %>
                    </span>
                  <% else %>
                    <span class="text-lg font-bold text-secondary">
                      <%= number_to_currency(price, unit: "₫", precision: 0, format: "%n %u") %>
                    </span>
                  <% end %>
                </div>
              </div>

              <%= link_to product_path(product), target: "_top", class: "w-full bg-primary/90 text-white text-center text-sm font-semibold py-3 rounded-lg hover:bg-primary transition-colors" do %>
                Xem chi tiết
              <% end %>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>

  <%= render 'shared/contact' %>
  <%= render 'shared/footer' %>
</main>
